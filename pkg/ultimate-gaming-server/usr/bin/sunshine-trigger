#!/bin/bash
# systemd injecte $REMOTE_ADDR pour les services Accept=yes — on sauvegarde
# l'IP du client Moonlight pour que le watchdog puisse vérifier sa présence.
MOONLIGHT_CLIENT_FILE=/tmp/sunshine-moonlight-client
[ -n "$REMOTE_ADDR" ] && echo "$REMOTE_ADDR" > "$MOONLIGHT_CLIENT_FILE"

# Démarre Sunshine (Conflicts dans sunshine.socket libère le port automatiquement).
systemctl --user start sunshine.service

# Maintient la connexion Moonlight ouverte jusqu'à ce que Sunshine écoute sur 47984.
# Quand ce script se termine, Moonlight retente immédiatement sur le vrai Sunshine.
for i in $(seq 1 30); do
    ss -tlnp 2>/dev/null | grep -q ':47984 ' && exit 0
    sleep 0.5
done
