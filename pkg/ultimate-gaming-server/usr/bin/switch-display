#!/usr/bin/env python3
"""
switch-display — Prépare DP-3 pour le stream wlr (Sunshine) ou restaure sa config normale.

virtual : éteint l'écran physique via DDC/CI (Wayland output DP-3 reste actif pour wlr-screencopy)
physical: rallume l'écran via DDC/CI et restaure la config DP-3 depuis monitors.conf
"""

import os
import subprocess
import sys
import time

PHYSICAL_MONITOR = "DP-3"
MONITORS_CONF = os.path.expanduser("~/.config/hypr/monitors.conf")
SESSION_FLAG = "/tmp/sunshine-gaming-session"


def hyprctl(*args):
    result = subprocess.run(
        ["hyprctl", "-i", "0"] + list(args),
        capture_output=True, text=True
    )
    return result.stdout.strip()


def get_original_monitor_config():
    """Lit la ligne monitor=DP-3,... depuis monitors.conf."""
    try:
        with open(MONITORS_CONF) as f:
            for line in f:
                line = line.strip()
                if line.startswith(f"monitor={PHYSICAL_MONITOR},"):
                    return line[len("monitor="):]
    except FileNotFoundError:
        pass
    return f"{PHYSICAL_MONITOR},preferred,0x0,1"


def ddc_power(on: bool):
    """Allume ou éteint l'écran physique via DDC/CI (luminosité) sans toucher au Wayland output."""
    # D6 (power) ignoré par ce monitor — on utilise la luminosité (0x10)
    brightness = "65" if on else "0"
    subprocess.run(
        ["ddcutil", "setvcp", "10", brightness],
        capture_output=True
    )


def switch_to_virtual():
    print("→ Passage en mode STREAM (wlr sur DP-3)...")
    ddc_power(False)
    open(SESSION_FLAG, "w").close()
    print("✓ Écran physique éteint via DDC, capture wlr sur DP-3.")


def switch_to_physical():
    print("→ Restauration de DP-3...")
    try:
        os.remove(SESSION_FLAG)
    except FileNotFoundError:
        pass
    ddc_power(True)
    time.sleep(0.3)
    original = get_original_monitor_config()
    print(f"  Restauration : {original}")
    hyprctl("keyword", "monitor", original)
    print("✓ DP-3 restauré.")


def main():
    mode = sys.argv[1].lower() if len(sys.argv) > 1 else "toggle"
    if mode == "virtual":
        switch_to_virtual()
    elif mode == "physical":
        switch_to_physical()
    elif mode == "toggle":
        if os.path.exists(SESSION_FLAG):
            switch_to_physical()
        else:
            switch_to_virtual()
    else:
        print(f"Unknown mode '{mode}'. Use: virtual | physical | toggle", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
