#!/bin/bash
# Arrête sunshine.service quand Moonlight n'est plus joignable.
# Deux critères combinés :
#   1. Plus de connexions TCP actives sur les ports Sunshine
#   2. Le client Moonlight a disparu de la table ARP (plus sur le réseau)
IDLE_TIMEOUT=60
MOONLIGHT_CLIENT_FILE=/tmp/sunshine-moonlight-client

idle=0
while true; do
    sleep 1

    # Connexions TCP actives sur les ports de contrôle Sunshine
    # ss --summary évite de forker grep : on lit directement stdout dans bash
    tcp_active=false
    while IFS= read -r line; do
        [[ "$line" =~ ^[0-9] ]] && { tcp_active=true; break; }
    done < <(ss -tno state established '( sport = :47984 or sport = :47989 or sport = :48010 )' 2>/dev/null)

    # Présence du client Moonlight dans la table ARP
    # ip neigh et awk remplacés par lecture directe de /proc/net/arp (pas de fork)
    moonlight_present=false
    if [[ -s "$MOONLIGHT_CLIENT_FILE" ]]; then
        read -r client_ip < "$MOONLIGHT_CLIENT_FILE"
        if [[ -n "$client_ip" ]]; then
            while IFS= read -r line; do
                if [[ "$line" == "$client_ip "* ]]; then
                    flags="${line##* }"
                    # flags 0x2 = REACHABLE, 0x4 = INCOMPLETE, 0x6 = STALE …
                    # on exclut seulement 0x0 (absent) et 0x4 (incomplete)
                    [[ "$flags" != "0x0" && "$flags" != "0x4" ]] && moonlight_present=true
                    break
                fi
            done < /proc/net/arp
        fi
    fi

    # Session de jeu active (flag posé par switch-display virtual)
    gaming_active=false
    [ -f /tmp/sunshine-gaming-session ] && gaming_active=true

    if $tcp_active || $moonlight_present || $gaming_active; then
        idle=0
    else
        idle=$((idle + 1))
        if [ "$idle" -ge "$IDLE_TIMEOUT" ]; then
            systemctl --user --no-block stop sunshine.service
            exit 0
        fi
    fi
done
