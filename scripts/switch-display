#!/usr/bin/env python3
"""
switch-display — Bascule entre la session Hyprland et le stream Xorg/NvFBC.

virtual : (DDC off optionnel) + loginctl activate VT Xorg (NvFBC prend DRM master)
physical: loginctl activate VT Hyprland + (DDC on optionnel) + restaure monitors.conf

Config : /etc/ultimate-gaming-server/switch-display.conf
"""

import os
import subprocess
import sys
import time

PHYSICAL_MONITOR = "DP-3"
MONITORS_CONF = os.path.expanduser("~/.config/hypr/monitors.conf")
SESSION_FLAG = "/tmp/sunshine-gaming-session"
XORG_INFO_FILE = "/tmp/xorg-stream-info"
CONFIG_FILE = "/etc/ultimate-gaming-server/switch-display.conf"


def load_config() -> dict:
    """Charge la config depuis /etc/ultimate-gaming-server/switch-display.conf."""
    defaults = {
        "DDC_SCREEN_OFF": "false",
        "DDC_BRIGHTNESS_OFF": "0",
        "DDC_BRIGHTNESS_ON": "65",
    }
    try:
        with open(CONFIG_FILE) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, _, v = line.partition("=")
                    defaults[k.strip()] = v.strip()
    except FileNotFoundError:
        pass
    return defaults


CFG = load_config()


def hyprctl(*args):
    result = subprocess.run(
        ["hyprctl", "-i", "0"] + list(args),
        capture_output=True, text=True
    )
    return result.stdout.strip()


def wait_for_hyprland_monitor(timeout: float = 8.0) -> bool:
    """Attend que Hyprland ait récupéré le DRM master (au moins un moniteur actif)."""
    import json
    deadline = time.time() + timeout
    while time.time() < deadline:
        result = subprocess.run(
            ["hyprctl", "-i", "0", "monitors", "-j"],
            capture_output=True, text=True
        )
        try:
            monitors = json.loads(result.stdout)
            if any(not m.get("disabled", True) for m in monitors):
                return True
        except (json.JSONDecodeError, ValueError):
            pass
        time.sleep(0.1)
    return False


def _find_native_mode(modes: set[str], width: int, height: int, fps: int) -> str | None:
    """Retourne un mode natif WxH si la fréquence demandée est dans sa liste xrandr."""
    import re
    prefix = f"{width}x{height}"
    for m in modes:
        if not m.startswith(prefix):
            continue
        # Extrait le refresh rate du nom (ex: "1920x1080" → pas de Hz, "3840x2160_60.00" → 60)
        match = re.search(r"_(\d+(?:\.\d+)?)$", m)
        if match and abs(float(match.group(1)) - fps) <= 1:
            return m
    return None


def xrandr_set_resolution(display: str, width: int, height: int, fps: int):
    """Applique la résolution/fréquence demandée par le client Moonlight via xrandr.

    DFP-0 est un display virtuel sans EDID : les modes doivent être créés via cvt.
    """
    env = {**os.environ, "DISPLAY": display, "XAUTHORITY": "/tmp/xauth-stream"}

    # Trouve l'output connecté (DFP-0 configuré comme ConnectedMonitor)
    result = subprocess.run(["xrandr", "--query"], capture_output=True, text=True, env=env)
    output = None
    existing_modes: set[str] = set()
    current_output = None
    for line in result.stdout.splitlines():
        if " connected " in line:
            output = line.split()[0]
            current_output = output
        elif current_output and line.startswith("   "):
            existing_modes.add(line.split()[0])

    if not output:
        print(f"  ⚠ xrandr: aucun output connecté sur {display}", file=sys.stderr)
        return

    # Cherche un mode natif exact (WxH à la bonne fréquence ±1 Hz)
    native_mode = _find_native_mode(existing_modes, width, height, fps)
    if native_mode:
        modeline_name = native_mode
        print(f"  xrandr: {output} → mode natif {modeline_name}")
    else:
        # Génère un modeline via cvt -r (reduced blanking) pour limiter le pixel clock.
        cvt = subprocess.run(
            ["cvt", "-r", str(width), str(height), str(fps)],
            capture_output=True, text=True
        )
        modeline_name = None
        params: list[str] = []
        for line in cvt.stdout.splitlines():
            if line.startswith("Modeline"):
                parts = line.split()
                modeline_name = parts[1].strip('"')
                params = parts[2:]
                break

        if not modeline_name:
            print(f"  ⚠ cvt: impossible de générer le modeline pour {width}x{height}@{fps}", file=sys.stderr)
            return

        subprocess.run(["xrandr", "--newmode", modeline_name] + params,
                       capture_output=True, env=env)

        if modeline_name not in existing_modes:
            r = subprocess.run(["xrandr", "--addmode", output, modeline_name],
                               capture_output=True, text=True, env=env)
            if r.returncode != 0:
                print(f"  ⚠ xrandr --addmode: {r.stderr.strip()}", file=sys.stderr)
                return

        print(f"  xrandr: {output} → {modeline_name} (cvt-r) @0x0 fb {width}x{height}")
    r = subprocess.run(
        ["xrandr",
         "--output", output, "--mode", modeline_name, "--pos", "0x0",
         "--fb", f"{width}x{height}"],
        capture_output=True, text=True, env=env
    )
    if r.returncode != 0:
        print(f"  ⚠ xrandr --mode: {r.stderr.strip()}", file=sys.stderr)


def get_original_monitor_config():
    """Lit la ligne monitor=DP-3,... depuis monitors.conf."""
    try:
        with open(MONITORS_CONF) as f:
            for line in f:
                line = line.strip()
                if line.startswith(f"monitor={PHYSICAL_MONITOR},"):
                    return line[len("monitor="):]
    except FileNotFoundError:
        pass
    return f"{PHYSICAL_MONITOR},preferred,0x0,1"


def ddc_power(on: bool):
    """Allume ou éteint l'écran physique via DDC/CI, si DDC_SCREEN_OFF=true."""
    if CFG.get("DDC_SCREEN_OFF", "false").lower() != "true":
        return
    brightness = CFG["DDC_BRIGHTNESS_ON"] if on else CFG["DDC_BRIGHTNESS_OFF"]
    subprocess.run(
        ["ddcutil", "setvcp", "10", brightness],
        capture_output=True
    )


def read_xorg_info() -> dict:
    """Lit le VT et le display depuis /tmp/xorg-stream-info."""
    info = {}
    try:
        with open(XORG_INFO_FILE) as f:
            for line in f:
                k, _, v = line.strip().partition("=")
                info[k] = v
    except FileNotFoundError:
        pass
    return info


def find_session_by_tty(tty: str) -> str | None:
    """Retourne le session ID loginctl correspondant à un TTY (ex: 'tty2')."""
    result = subprocess.run(
        ["loginctl", "list-sessions", "--no-legend", "--no-pager"],
        capture_output=True, text=True
    )
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 5 and parts[4] == tty:
            return parts[0]
    return None


def find_hyprland_tty() -> str | None:
    """Trouve le TTY de la session Hyprland via loginctl."""
    result = subprocess.run(
        ["loginctl", "list-sessions", "--no-legend", "--no-pager"],
        capture_output=True, text=True
    )
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 5 and parts[4].startswith("tty"):
            # Vérifie si la session est de type wayland
            show = subprocess.run(
                ["loginctl", "show-session", parts[0], "-p", "Type", "--value"],
                capture_output=True, text=True
            )
            if show.stdout.strip() == "wayland":
                return parts[4]
    return None


def chvt(vt: int):
    """Bascule sur un VT via chvt (fonctionne avec ou sans session logind)."""
    subprocess.run(["sudo", "chvt", str(vt)], check=True)
    print(f"  → chvt {vt}")


def activate_tty(tty: str):
    """Bascule sur un TTY. Essaie loginctl d'abord, chvt en fallback."""
    vt = int(tty.replace("tty", ""))
    session_id = find_session_by_tty(tty)
    if session_id:
        subprocess.run(["loginctl", "activate", session_id], check=True)
        print(f"  → loginctl activate {session_id} ({tty})")
    else:
        chvt(vt)


def wait_for_xorg(display: str, timeout: float = 5.0) -> bool:
    """Attend que le socket Unix du X server soit accessible (sans xdpyinfo)."""
    import socket as _socket
    # Extrait le numéro de display (:1 → 1)
    try:
        n = int(display.lstrip(":").split(".")[0])
    except ValueError:
        n = 1
    sock_path = f"/tmp/.X11-unix/X{n}"
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
            s.connect(sock_path)
            s.close()
            return True
        except OSError:
            time.sleep(0.2)
    return False


def kill_desktop_launchers():
    """Tue Lutris et Steam avant le switch pour forcer leur redémarrage sur DISPLAY=:2.

    Ces applications sont à instance unique via D-Bus : sans ce kill, elles activent
    l'instance existante sur Hyprland et le jeu s'ouvre sur le mauvais display.
    """
    for name in ("lutris", "steam"):
        result = subprocess.run(["pkill", "-x", name], capture_output=True)
        if result.returncode == 0:
            print(f"  killed {name}")
    time.sleep(0.5)


def switch_to_virtual():
    print("→ Passage en mode STREAM (Xorg NvFBC)...")
    ddc_power(False)

    info = read_xorg_info()
    xorg_vt = info.get("vt")
    xorg_display = info.get("display", ":1")
    if not xorg_vt:
        print("  ✗ VT Xorg introuvable dans xorg-stream-info", file=sys.stderr)
        sys.exit(1)

    # Tue les launchers à instance unique pour qu'ils redémarrent sur DISPLAY=:2
    kill_desktop_launchers()

    # Sauvegarde le VT courant (Hyprland) pour le retour
    current_vt_file = "/tmp/hyprland-vt"
    try:
        with open("/sys/class/tty/tty0/active") as f:
            current_vt = f.read().strip()  # ex: "tty2"
        with open(current_vt_file, "w") as f:
            f.write(current_vt)
    except Exception:
        pass

    chvt(int(xorg_vt))

    # Attend que Xorg soit actif (DRM master acquis)
    if not wait_for_xorg(xorg_display):
        print("  ⚠ Xorg ne répond pas après 5s sur " + xorg_display, file=sys.stderr)

    # Résolution selon les paramètres Moonlight, fallback 1920x1080@60
    try:
        width  = int(os.environ.get("SUNSHINE_CLIENT_WIDTH",  0)) or 1920
        height = int(os.environ.get("SUNSHINE_CLIENT_HEIGHT", 0)) or 1080
        fps    = int(os.environ.get("SUNSHINE_CLIENT_FPS",    0)) or 60
        xrandr_set_resolution(xorg_display, width, height, fps)
    except (ValueError, TypeError):
        pass

    open(SESSION_FLAG, "w").close()
    print(f"✓ VT{xorg_vt} actif, Xorg prêt sur {xorg_display} (NvFBC).")


def switch_to_physical():
    print("→ Restauration du bureau Hyprland...")
    try:
        os.remove(SESSION_FLAG)
    except FileNotFoundError:
        pass

    # Retour au VT Hyprland. xorg-stream reste vivant (service système) — il n'est
    # jamais redémarré pendant qu'un compositor est actif. Le contexte NvFBC sera
    # recréé proprement au prochain lancement de sunshine.service (watchdog l'aura
    # arrêté entre-temps).
    try:
        with open("/tmp/hyprland-vt") as f:
            saved_tty = f.read().strip()  # ex: "tty2"
        vt = int(saved_tty.replace("tty", ""))
        chvt(vt)
    except Exception:
        hypr_tty = find_hyprland_tty()
        if hypr_tty:
            activate_tty(hypr_tty)
        else:
            print("  ⚠ VT Hyprland introuvable.", file=sys.stderr)

    if not wait_for_hyprland_monitor():
        print("  ⚠ Hyprland ne signale aucun moniteur actif après 8s", file=sys.stderr)
    ddc_power(True)

    original = get_original_monitor_config()
    print(f"  Restauration monitor : {original}")
    hyprctl("keyword", "monitor", original)
    print("✓ Hyprland restauré, DP-3 actif.")


def main():
    mode = sys.argv[1].lower() if len(sys.argv) > 1 else "toggle"
    if mode == "virtual":
        switch_to_virtual()
    elif mode == "physical":
        switch_to_physical()
    elif mode == "toggle":
        if os.path.exists(SESSION_FLAG):
            switch_to_physical()
        else:
            switch_to_virtual()
    else:
        print(f"Unknown mode '{mode}'. Use: virtual | physical | toggle", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
