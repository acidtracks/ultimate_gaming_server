#!/usr/bin/env python3
"""
start-sunshine — Lance Sunshine avec le backend KMS.

La capture se fait directement sur DP-3 via KMS (pas de moniteur headless).
Le basculement résolution/DPMS est géré par global_prep_cmd → switch-display.
"""

import os
import sys

SUNSHINE_BIN = "/usr/bin/sunshine"


def main():
    print(f"[..] Lancement de Sunshine...")
    os.execv(SUNSHINE_BIN, [SUNSHINE_BIN] + sys.argv[1:])


if __name__ == "__main__":
    main()
